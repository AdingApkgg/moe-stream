# ============================================================
# Docker/Podman Compose 配置（使用容器时设置）
# ============================================================
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="your_password"
POSTGRES_DB="acgn"

# ============================================================
# 数据库连接（必须）
# ============================================================
# 本地开发: postgresql://user:password@localhost:5432/acgn?schema=public
# Docker:   由 compose.yaml 自动配置，无需设置
DATABASE_URL="postgresql://user:password@localhost:5432/acgn?schema=public"

# ============================================================
# Redis 连接（必须）
# ============================================================
# 本地开发: redis://localhost:6379
# Docker:   由 compose.yaml 自动配置，无需设置
REDIS_URL="redis://localhost:6379"

# ============================================================
# Better Auth（必须）
# ============================================================
# 生成密钥: openssl rand -base64 32
BETTER_AUTH_SECRET="your-secret-key-here"

# ============================================================
# 以上 3 项为唯一必须的环境变量
# 其余所有配置（SMTP、上传目录、搜索引擎推送、站点信息等）
# 均可在后台「系统设置」中管理，无需配置环境变量。
#
# 首次启动时会自动进入初始配置向导（/setup），
# 引导你创建管理员账户和基本站点设置。
# ============================================================

# ============================================================
# 可选环境变量（仅用于 fallback，优先从后台读取）
# ============================================================

# 站点 URL（后台设置中的「站点 URL」优先级更高）
# NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ============================================================
# Compose 容器名前缀（可选）
# ============================================================
APP_NAME="acgn"
