# ============================================================
# 开发环境配置模板
# ============================================================
# 复制此文件为 .env.development 后修改:
#   cp .env.development.example .env.development
# ============================================================

# 数据库连接（本地 / compose:infra）
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/acgn?schema=public"

# Redis 连接（本地 / compose:infra）
REDIS_URL="redis://localhost:6379"

# Meilisearch（pnpm compose:infra 后默认 http://127.0.0.1:7700）
MEILISEARCH_URL="http://127.0.0.1:7700"
MEILISEARCH_MASTER_KEY="dev-meili-master-key-change-me"
# Compose 中的 meilisearch 容器需要同名变量（与 MEILISEARCH_MASTER_KEY 一致即可）
MEILI_MASTER_KEY="dev-meili-master-key-change-me"

# Better Auth 密钥（开发环境可用任意值，至少 32 字符）
BETTER_AUTH_SECRET="dev-secret-key-change-me-in-production!!"

# 站点 URL（可选，后台设置优先）
# NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Socket 服务 URL（可选，默认 ws://localhost:3001）
# NEXT_PUBLIC_SOCKET_URL="ws://localhost:3001"
