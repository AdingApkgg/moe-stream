// ==================== 数据备份 ====================

model BackupRecord {
  id            String       @id @default(cuid())
  filename      String
  size          BigInt       @default(0)        // 文件大小（字节）
  type          BackupType   @default(MANUAL)
  status        BackupStatus @default(PENDING)
  errorMessage  String?      @db.Text
  storagePath   String?                         // 对象存储中的 key
  includes      Json?                           // { database: true, uploads: true, config: true }
  createdAt     DateTime     @default(now())
  completedAt   DateTime?

  @@index([createdAt])
  @@index([status])
}

enum BackupType {
  AUTO
  MANUAL
}

enum BackupStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

// ==================== 贴图包 ====================

model StickerPack {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  coverUrl    String?
  isActive    Boolean   @default(true)
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  stickers    Sticker[]
}

model Sticker {
  id          String      @id @default(cuid())
  packId      String
  name        String
  imageUrl    String
  width       Int?
  height      Int?
  sortOrder   Int         @default(0)
  createdAt   DateTime    @default(now())
  pack        StickerPack @relation(fields: [packId], references: [id], onDelete: Cascade)

  @@index([packId, sortOrder])
}

// ==================== 推广系统 ====================

model ReferralLink {
  id            String   @id @default(cuid())
  userId        String
  code          String   @unique
  label         String?
  channel       String?
  targetUrl     String?
  clicks        Int      @default(0) // 总点击（含重复）
  uniqueClicks  Int      @default(0) // 去重点击（同一访客同日仅计一次）
  registers     Int      @default(0)
  paymentCount  Int      @default(0) // 充值笔数
  paymentAmount Float    @default(0) // 充值总额
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  records       ReferralRecord[]
  dailyStats    ReferralDailyStat[]
  clickLogs     ReferralClick[]
  paymentOrders PaymentOrder[]

  @@index([userId])
}

model ReferralClick {
  id             String   @id @default(cuid())
  referralLinkId String
  visitorHash    String   // SHA-256(IP + UserAgent) 用于去重
  ip             String?  // 原始 IP（可供管理员审计）
  referer        String?  // HTTP Referer
  date           DateTime @db.Date
  createdAt      DateTime @default(now())

  referralLink ReferralLink @relation(fields: [referralLinkId], references: [id], onDelete: Cascade)

  @@unique([referralLinkId, visitorHash, date])
  @@index([referralLinkId, date])
  @@index([date])
}

model ReferralDailyStat {
  id             String   @id @default(cuid())
  referralLinkId String
  userId         String
  date           DateTime @db.Date
  clicks         Int      @default(0) // 总点击
  uniqueClicks   Int      @default(0) // 去重点击
  registers      Int      @default(0)
  paymentCount   Int      @default(0) // 充值笔数
  paymentAmount  Float    @default(0) // 充值金额

  referralLink ReferralLink @relation(fields: [referralLinkId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([referralLinkId, date])
  @@index([userId, date])
  @@index([date])
}

model ReferralRecord {
  id              String    @id @default(cuid())
  referrerId      String
  referredUserId  String    @unique
  referralLinkId  String?
  pointsAwarded   Int       @default(0)
  hasPaid         Boolean   @default(false)
  firstPaidAt     DateTime?
  createdAt       DateTime  @default(now())

  referrer     User          @relation("Referrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referredUser User          @relation("ReferredUser", fields: [referredUserId], references: [id], onDelete: Cascade)
  referralLink ReferralLink? @relation(fields: [referralLinkId], references: [id], onDelete: SetNull)

  @@index([referrerId])
  @@index([referralLinkId])
}

model PointsTransaction {
  id          String                @id @default(cuid())
  userId      String
  amount      Int
  balance     Int
  type        PointsTransactionType
  description String?
  relatedId   String?
  createdAt   DateTime              @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

enum PointsTransactionType {
  REFERRAL_REWARD
  ADMIN_ADJUST
  POINTS_CONSUME
  DAILY_LOGIN
  CHECKIN
  WATCH_VIDEO
  LIKE_VIDEO
  FAVORITE_VIDEO
  COMMENT_VIDEO
  VIEW_GAME
  LIKE_GAME
  FAVORITE_GAME
  COMMENT_GAME
  VIEW_IMAGE
  LIKE_IMAGE
  FAVORITE_IMAGE
  COMMENT_IMAGE
  REDEEM_CODE
  USDT_RECHARGE
}

// ==================== 兑换码 ====================

model RedeemCode {
  id            String    @id @default(cuid())
  code          String    @unique
  description   String?
  pointsAmount  Int       @default(0)
  grantUpload   Boolean   @default(false)
  maxUses       Int       @default(1)
  usedCount     Int       @default(0)
  expiresAt     DateTime?
  isActive      Boolean   @default(true)
  batchId       String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  redemptions RedeemCodeRedemption[]

  @@index([batchId])
  @@index([isActive, expiresAt])
}

model RedeemCodeRedemption {
  id         String   @id @default(cuid())
  codeId     String
  userId     String
  createdAt  DateTime @default(now())

  code RedeemCode @relation(fields: [codeId], references: [id], onDelete: Cascade)
  user User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([codeId, userId])
  @@index([codeId])
  @@index([userId])
}

// ==================== USDT 支付 ====================

model PaymentPackage {
  id           String   @id @default(cuid())
  name         String
  amount       Float    // USDT 价格
  pointsAmount Int      @default(0)
  grantUpload  Boolean  @default(false)
  description  String?
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  orders PaymentOrder[]

  @@index([isActive, sortOrder])
}

model PaymentOrder {
  id             String        @id @default(cuid())
  userId         String
  orderNo        String        @unique
  amount         Float         // 实际支付金额（含差异化小数）
  baseAmount     Float         // 原始金额
  chain          String        @default("TRC20")
  walletAddress  String
  txHash         String?       @unique
  status         PaymentStatus @default(PENDING)
  packageId      String?
  referralLinkId String?
  pointsAmount   Int           @default(0)
  grantUpload    Boolean       @default(false)
  description    String?
  expiresAt      DateTime
  paidAt         DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  package      PaymentPackage? @relation(fields: [packageId], references: [id], onDelete: SetNull)
  referralLink ReferralLink?   @relation(fields: [referralLinkId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([status, expiresAt])
  @@index([amount, status])
  @@index([referralLinkId])
}

enum PaymentStatus {
  PENDING
  PAID
  EXPIRED
  CANCELLED
}

// ==================== 通讯系统 ====================

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("followers", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followingId])
}

enum NotificationType {
  COMMENT_REPLY
  LIKE
  FAVORITE
  SYSTEM
  NEW_MESSAGE
  CONTENT_STATUS
  FOLLOW
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  content   String?
  data      Json?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
}

model Conversation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participants ConversationParticipant[]
  messages     DirectMessage[]
}

model ConversationParticipant {
  id             String    @id @default(cuid())
  conversationId String
  userId         String
  lastReadAt     DateTime?
  joinedAt       DateTime  @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
}

enum MessageType {
  TEXT
  IMAGE
  FILE
  STICKER
  SYSTEM
}

model DirectMessage {
  id             String      @id @default(cuid())
  conversationId String
  senderId       String
  content        String?
  type           MessageType @default(TEXT)
  metadata       Json?
  isDeleted      Boolean     @default(false)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

enum ChannelType {
  PUBLIC
  PRIVATE
}

enum ChannelRole {
  OWNER
  ADMIN
  MEMBER
}

model Channel {
  id          String      @id @default(cuid())
  name        String
  slug        String      @unique
  description String?
  avatarUrl   String?
  type        ChannelType @default(PUBLIC)
  creatorId   String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  creator  User             @relation(fields: [creatorId], references: [id])
  members  ChannelMember[]
  messages ChannelMessage[]

  @@index([slug])
}

model ChannelMember {
  id         String      @id @default(cuid())
  channelId  String
  userId     String
  role       ChannelRole @default(MEMBER)
  lastReadAt DateTime?
  joinedAt   DateTime    @default(now())

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
  @@index([userId])
}

model ChannelMessage {
  id        String      @id @default(cuid())
  channelId String
  senderId  String
  content   String?
  type      MessageType @default(TEXT)
  metadata  Json?
  replyToId String?
  isDeleted Boolean     @default(false)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  channel Channel         @relation(fields: [channelId], references: [id], onDelete: Cascade)
  sender  User            @relation(fields: [senderId], references: [id], onDelete: Cascade)
  replyTo ChannelMessage? @relation("ChannelMessageReply", fields: [replyToId], references: [id])
  replies ChannelMessage[] @relation("ChannelMessageReply")

  @@index([channelId, createdAt])
}

// ==================== 留言板 ====================

model GuestbookMessage {
  id            String   @id @default(cuid())
  content       String   @db.Text
  userId        String?
  guestName     String?
  guestEmail    String?
  guestWebsite  String?

  ipv4Address   String?
  ipv4Location  String?
  ipv6Address   String?
  ipv6Location  String?
  deviceInfo    Json?
  userAgent     String?

  likes         Int      @default(0)
  isDeleted     Boolean  @default(false)
  isHidden      Boolean  @default(false)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User? @relation("GuestbookAuthor", fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([userId])
}

// ==================== 友情链接 ====================

model FriendLink {
  id          String   @id @default(cuid())
  name        String                         // 站点名称
  url         String                         // 站点链接
  logo        String?                        // 站点 logo URL
  description String?                        // 站点描述
  sort        Int      @default(0)           // 排序（越大越靠前）
  visible     Boolean  @default(true)        // 是否显示
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([sort])
}

// ==================== 存储策略 & 用户文件 ====================

model StoragePolicy {
  id              String   @id @default(cuid())
  name            String   @unique
  provider        String   // local | s3 | r2 | minio | oss | cos
  endpoint        String?
  bucket          String?
  region          String?
  accessKey       String?
  secretKey       String?
  customDomain    String?
  pathPrefix      String?
  uploadDir       String?  // local 模式

  maxFileSize     BigInt   @default(1073741824) // 1GB
  allowedTypes    String[] @default([])
  isDefault       Boolean  @default(false)
  enabled         Boolean  @default(true)
  sortOrder       Int      @default(0)

  files           UserFile[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model UserFile {
  id              String     @id @default(cuid())
  userId          String
  storagePolicyId String

  filename        String
  storageKey      String
  url             String
  mimeType        String
  size            BigInt
  hash            String?

  contentType     String?    // "video" | "game" | "imagePost"
  contentId       String?

  // 断点续传
  s3UploadId      String?    // S3 multipart upload ID（持久化以支持恢复）
  totalChunks     Int?       // 总分片数
  uploadedChunks  Json?      // 已完成的分片 [{ index: number, etag?: string }]

  status          FileStatus @default(UPLOADING)
  uploadedAt      DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  storagePolicy   StoragePolicy @relation(fields: [storagePolicyId], references: [id])
  importTasks     ImportTask[]

  @@index([userId])
  @@index([storagePolicyId])
  @@index([contentType, contentId])
  @@index([status])
  @@index([hash])
}

enum FileStatus {
  UPLOADING
  UPLOADED
  FAILED
  DELETED
}

// ==================== 网盘导入任务 ====================

model ImportTask {
  id              String       @id @default(cuid())
  userId          String
  provider        String       // "google" | "onedrive" | "dropbox" | "url"
  sourceUrl       String       @db.Text
  sourceFileId    String?      // 网盘文件 ID
  sourceName      String       // 原始文件名
  sourceSize      BigInt?      // 预估大小
  sourceMimeType  String?

  status          ImportStatus @default(PENDING)
  progress        Int          @default(0)   // 0-100
  downloadedBytes BigInt       @default(0)
  error           String?      @db.Text

  userFileId      String?      // 下载完成后关联的 UserFile

  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userFile        UserFile?    @relation(fields: [userFileId], references: [id])

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([userId])
  @@index([status])
}

enum ImportStatus {
  PENDING
  DOWNLOADING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

/// 用户 API Key，用于通过 HTTP API 发布内容
model ApiKey {
  id         String    @id @default(cuid())
  name       String    /// 用户自定义名称（如"爬虫脚本"）
  keyHash    String    @unique /// SHA-256(完整 key)，不存储明文
  keyPrefix  String    /// key 前缀，用于列表展示（sk-abcd****）
  scopes     String[]  /// 权限范围 ["video", "game", "image"]
  lastUsedAt DateTime? /// 最后使用时间
  expiresAt  DateTime? /// 过期时间（null = 永不过期）
  createdAt  DateTime  @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([keyHash])
  @@index([userId])
}
