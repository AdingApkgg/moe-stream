    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@serwist/cli": "^9.5.7",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^6.0.1",
    "cheerio": "^1.2.0",
    "concurrently": "^9.2.1",
    "critters": "^0.0.25",
    "eslint": "^9.39.3",
    "eslint-config-next": "16.2.1",
    "lint-staged": "^16.4.0",
    "prisma": "^7.6.0",
    "puppeteer-core": "^24.40.0",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "biome check --write --unsafe",
      "eslint --fix --no-warn-ignored"
    ],
    "*.{js,mjs,cjs,json,css}": [
      "biome check --write --unsafe"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@prisma/engines",
      "@swc/core",
      "esbuild",
      "prisma",
      "sharp",
      "unrs-resolver"
    ]
  },
  "packageManager": "pnpm@10.33.0"
}
