{
  "name": "moe-stream",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently --kill-others-on-fail -n next,socket -c blue,green \"next dev --turbopack --hostname 0.0.0.0\" \"DOTENV_CONFIG_PATH=.env.development tsx watch --require dotenv/config src/socket/server.ts\"",
    "prepare": "simple-git-hooks",
    "dev:next": "next dev --turbopack --hostname 0.0.0.0",
    "dev:socket": "DOTENV_CONFIG_PATH=.env.development tsx watch --require dotenv/config src/socket/server.ts",
    "build": "prisma generate && next build && serwist build",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . && tsc --noEmit",
    "lint:eslint": "eslint .",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "tauri:dev": "cargo tauri dev",
    "tauri:build:mikiacg": "cargo tauri build --config src-tauri/configs/mikiacg.json",
    "tauri:build:aiacg": "cargo tauri build --config src-tauri/configs/aiacg.json",
    "tauri:build:all": "pnpm tauri:build:mikiacg && pnpm tauri:build:aiacg",
    "db:seed": "tsx prisma/seed.ts",
    "deploy": "./deploy.sh",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:stop": "pm2 stop ecosystem.config.cjs",
    "pm2:restart": "pm2 restart ecosystem.config.cjs",
    "pm2:logs": "pm2 logs ecosystem.config.cjs",
    "pm2:status": "pm2 status",
    "script:migrate-auth": "NODE_ENV=production tsx scripts/migrate-better-auth.ts",
    "script:create-user": "NODE_ENV=production tsx scripts/create-user.ts",
    "script:create-owner": "NODE_ENV=production tsx scripts/create-owner.ts",
    "script:fetch-videos": "tsx scripts/fetch-legacy-site.ts",
    "script:fetch-games": "tsx scripts/fetch-legacy-games.ts",
    "compose:infra": "podman compose up -d postgres redis",
    "compose:up": "podman compose up -d",
    "compose:down": "podman compose down",
    "compose:logs": "podman compose logs -f",
    "compose:build": "podman compose build --no-cache",
    "systemd:install": "sudo ./systemd/install.sh",
    "systemd:start": "sudo systemctl start moestream.target",
    "systemd:stop": "sudo systemctl stop moestream.target",
    "systemd:restart": "sudo systemctl restart moestream.target",
    "systemd:status": "systemctl status moestream-app moestream-socket",
    "systemd:logs": "journalctl -u moestream-app -u moestream-socket -f",
    "deploy:systemd": "./deploy.sh --systemd"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1019.0",
    "@aws-sdk/s3-request-presigner": "^3.1019.0",
    "@better-auth/passkey": "^1.5.6",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
