    "dayjs": "^1.11.20",
    "dotenv": "^17.3.1",
    "framer-motion": "^12.38.0",
    "handlebars": "^4.7.9",
    "hash-wasm": "^4.12.0",
    "hls.js": "^1.6.15",
    "ioredis": "^5.10.1",
    "ip2region.js": "^3.1.8",
    "jose": "^6.2.2",
    "lucide-react": "^1.7.0",
    "nanoid": "^5.1.7",
    "next": "16.2.1",
    "next-mdx-remote": "^6.0.0",
    "next-themes": "^0.4.6",
    "nodemailer": "^8.0.4",
    "pg": "^8.20.0",
