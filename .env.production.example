# 生产环境配置示例
# 复制此文件为 .env.production 并填写实际值
#
# 仅需配置以下 3 个必须变量，其余配置通过后台「系统设置」管理。
# 首次启动会自动进入初始配置向导（/setup）。

# Database（必须）
DATABASE_URL="postgresql://user:password@localhost:5432/acgn?schema=public"

# Redis（必须）
REDIS_URL="redis://localhost:6379"

# Meilisearch（必须；systemd 二进制与 Node 应用共用）
MEILISEARCH_URL="http://127.0.0.1:7700"
MEILISEARCH_MASTER_KEY="openssl-rand-base64-32-here"
# systemd meilisearch.service 读取官方变量名（与上密钥一致）
MEILI_MASTER_KEY="openssl-rand-base64-32-here"

# Better Auth（必须）
# 生成方式: openssl rand -base64 32
BETTER_AUTH_SECRET="your-secret-key-here"

# 站点 URL（可选 fallback，优先从后台设置读取）
# NEXT_PUBLIC_APP_URL="https://your-domain.com"
